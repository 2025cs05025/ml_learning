# Line length / imports-after-sys.path (scripts add src/ before project imports)
# Author: SANDIP BHATTACHARYYA — BITS Pilani ID 2025cs05025
[flake8]
max-line-length = 120
extend-ignore = E402, W503
exclude =
    .venv,
    .venv-*,
    .venv-test-reqs,
    venv,
    __pycache__,
    .git,
    mlruns,
    .pytest_cache,
    .mypy_cache,
